generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"

}

// ==========================================
// ENUMS (Pilihan Terbatas)
// ==========================================

enum ThemePreference {
  system
  dark
  light
}

enum SectionSource {
  projects
  competitions
  career
  education
}

enum HeaderStyle {
  center_badge
  simple_left
}

enum NavType {
  home
  section_link
  social_link
  external_link
}

enum CareerCategory {
  work
  organization
}

// ==========================================
// MODELS (Tabel)
// ==========================================

// 1. User Root (Mapping ke Supabase Auth User ID)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  emailVerified Boolean  @default(false) @map("email_verified")
  image    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions Session[]
  account Account[]

  // Relasi ke Tabel Lain
  profile        Profile?
  siteConfig     SiteConfig?
  socialLinks    SocialLink[]
  sections       Section[]
  navItems       NavItem[]
  projects       Project[]
  projectCategories ProjectCategory[]
  competitions   Competition[]
  careerJourneys CareerJourney[]
  educations     Education[]

  @@map("user") // better auth default table name
}


// model session khusus better auth
model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  token        String   @unique
  expiresAt    DateTime @map("expires_at")
  ipAddress   String   @map("ip_address")
  userAgent   String   @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session") // better auth default table name
}

// model account khusus better auth
model Account {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  accountId      String   @map("account_id")
  providerId     String   @map("provider_id")
  accessToken   String?   @map("access_token")
  refreshToken  String?  @map("refresh_token")
  accessTokenExpiresAt DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope         String?
  idToken      String? @map("id_token")
  password String?

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account") // better auth default table name
}

// Model Verifikasi Better Auth
model VerificationToken {
  id        String   @id @default(uuid())
  identifier String
  value    String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("verificationk")
}

// model bisnis utama aplikasi portofolio

model Profile {
  id           String  @id @default(uuid())
  userId       String  @unique @map("user_id") // One-to-One
  name         String
  initial      String  @db.VarChar(3)
  tagline      String
  location     String?
  locationLink String? @map("location_link")
  description  String? @db.Text // Short intro
  summary      String? @db.Text // Rich Text
  avatarUrl    String  @map("avatar_url")
  resumeUrl    String? @map("resume_url")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model SiteConfig {
  id              String          @id @default(uuid())
  userId          String          @unique @map("user_id") // One-to-One
  themePreference ThemePreference @default(system) @map("theme_preference")
  seoTitle        String          @map("seo_title")
  seoDescription  String?         @map("seo_description")
  seoKeywords     String[]        @map("seo_keywords") // Array of String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("site_configs")
}

model SocialLink {
  id       String  @id @default(uuid())
  userId   String  @map("user_id")
  platform String
  url      String
  iconKey  String  @map("icon_key")
  isActive Boolean @default(true) @map("is_active")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("social_links")
}

// 3. Group: Layout Manager (The Brain)

model Section {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  contentSource SectionSource @map("content_source")
  orderIndex    Int           @map("order_index")
  isVisible     Boolean       @default(true) @map("is_visible")

  // Header Configuration
  headerStyle HeaderStyle @map("header_style") // Auto-filled by logic
  heading     String
  subHeading  String?     @map("sub_heading")
  badgeText   String?     @map("badge_text") // Nullable (Only for Card/Timeline)
  description String?     @db.Text // Nullable

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sections")
}

model NavItem {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  orderIndex  Int     @map("order_index")
  type        NavType
  label       String  @db.VarChar(20)
  iconKey     String  @map("icon_key")
  targetValue String? @map("target_value") // URL or Section ID

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nav_items")
}

// 4. Group: Content Data (The Repository)

model Project {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  title      String
  slug       String
  content    String?  @db.Text // Rich Text
  techStack  String[] @map("tech_stack") // Array of String
  thumbnail  String
  demoUrl    String?  @map("demo_url")
  repoUrl    String?  @map("repo_url")
  isFeatured Boolean  @default(false) @map("is_featured")

  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  categories ProjectCategory[]

  // Unik: User tidak boleh punya 2 project dengan slug yang sama
  @@unique([userId, slug])
  @@map("projects")
}

model Competition {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  title       String // Event Name
  organizer   String
  dateDisplay String  @map("date_display") // "Nov 2023"
  description String? @db.Text
  websiteUrl  String? @map("website_url")
  repoUrl     String? @map("repo_url")

  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("competitions")
}

model CareerJourney {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  category    CareerCategory
  place       String // Company or Organization Name
  role        String
  period      String
  description String?        @db.Text
  location    String?
  logoUrl     String?        @map("logo_url")

  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("career_journeys")
}

model Education {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  institution String
  degree      String
  period      String
  description String? @db.Text
  logoUrl     String?        @map("logo_url")

  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("educations")
}

model ProjectCategory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  
  projects  Project[]
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("project_categories")
}